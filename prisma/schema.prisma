generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// วาง Model User ไว้รอเลยครับ
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String
  gender          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
